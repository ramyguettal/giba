# App
APP_ENV=development
SECRET_KEY=your-secret-key-here
APP_PORT=8000

# Database
# Preferred: Supabase Postgres connection string.
# Example (direct connection):
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# If you use Supabase's connection pooler, the host/port differ (often port 6543).
DATABASE_URL=

# Supabase requires SSL. Leave empty for a local (non-SSL) Postgres.
DATABASE_SSLMODE=require

# Legacy settings (used only when DATABASE_URL is empty)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=giba_maintainance_assistant
POSTGRES_USER=giba_user
POSTGRES_PASSWORD=your-db-password

# Vector DB (Postgres + pgvector)
# Ensure the Postgres instance has the pgvector extension enabled (migration creates it).
VECTOR_TABLE=vector_documents
# voyage-3.5 produces 1024-dimensional embeddings.
VECTOR_EMBEDDING_DIM=1024

# Embeddings (Voyage AI) — https://docs.voyageai.com/docs/embeddings
VOYAGE_API_KEY=your-voyage-key
VOYAGE_MODEL=voyage-3.5

# LLM for grounded answer generation (OpenCode Zen, OpenAI-compatible)
OPENCODE_API_KEY=your-opencode-key
OPENCODE_MODEL=deepseek-v4-flash

# JWT
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Bootstrap admin (created on startup if it does not exist)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_ALLOWED_MACHINES=HyPET5e

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
