# App
APP_ENV=development
SECRET_KEY=your-secret-key-here
APP_PORT=8000

# Database
# Preferred: Supabase Postgres connection string.
# Example (direct connection):
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# If you use Supabase's connection pooler, the host/port differ (often port 6543).
DATABASE_URL=

# Supabase requires SSL.
DATABASE_SSLMODE=require

# Legacy settings (used only when DATABASE_URL is empty)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=giba_hr
POSTGRES_USER=giba_user
POSTGRES_PASSWORD=your-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Vector DB (Postgres + pgvector)
# Ensure the Postgres instance has the pgvector extension enabled (migration creates it).
VECTOR_TABLE=vector_documents

# LLM (Groq)
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama3-70b-8192

# JWT
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
